{
  "name": "nestjs-prisma-boilerplate",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "isoftchamp",
  "engines": {
    "node": ">=20.0.0",
    "npm": "please-use-yarn",
    "yarn": ">= 1.19.1",
    "pnpm": "please-use-yarn"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"(src|test|prisma)/**/*.(js|mjs|cjs|jsx|ts|json|json5|jsonc|yml|yaml|md|markdown|graphql|gql|ng|sql|prisma)\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "dev:worker": "nest start --entryFile worker --watch",
    "debug": "nest start --debug --watch",
    "debug:worker": "nest start --entryFile worker --debug --watch",
    "prod": "node build/web",
    "prod:worker": "node build/worker",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./test/jest.json --forceExit",
    "test:watch": "jest --watch --config ./test/jest.json --forceExit",
    "test:cov": "jest --coverage --config ./test/jest.json --forceExit",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand --config ./test/jest.json --forceExit",
    "test:e2e": "jest --config ./test/jest-e2e.json --forceExit",
    "test:e2e:watch": "jest --watch --config ./test/jest-e2e.json --forceExit",
    "pre-commit": "lint-staged",
    "doppler:dev": "doppler run --config dev -- npm run dev",
    "doppler:dev:worker": "doppler run --config dev -- npm run dev:worker",
    "doppler:test": "doppler run --config test -- npm run test",
    "doppler:test:e2e": "doppler run --config test -- npm run test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.3",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.20",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/platform-socket.io": "^10.4.20",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/websockets": "^10.4.20",
    "@prisma/client": "^6",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.3.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.60.0",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^5.1.4",
    "chalk": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "lodash": "^4.17.21",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.2",
    "socket.io": "^4.7.5",
    "socket.io-adapter": "^2.5.4",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-mongodb": "^7.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.20",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/bcrypt": "^5.0.2",
    "@types/chalk": "^2.2.4",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.20",
    "@types/node": "^20.19.19",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^6.15.0",
    "socket.io-client": "^4.7.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "webpack": "^5.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{json,json5,jsonc,yml,yaml,md,markdown,graphql,gql,ng,sql,prisma}": [
      "prettier --write"
    ]
  }
}
